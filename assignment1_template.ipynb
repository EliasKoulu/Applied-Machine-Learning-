    "# 1. Putken järjestys (Skaalaus -> PCA -> SMOTE -> Malli)\n",
    "rf_pipeline = ImbPipeline([\n",
    "    ('scaler', StandardScaler()), \n",
    "    ('pca', 'passthrough'), \n",
    "    ('smote', SMOTE(random_state=42)),\n",
    "    ('rf', RandomForestClassifier(random_state=42))\n",
    "])\n",
    "\n",
    "# 2. Testattavat hyperparametrit, esikäsittelyt ja PCA\n",
    "param_grid = {\n",
    "    # Testataan skaalaimet\n",
    "    'scaler': [StandardScaler(), MinMaxScaler(), 'passthrough'],\n",
    "    \n",
    "    # Testataan PCA (komponenttien määrät ja ilman PCA:ta)\n",
    "    'pca': [PCA(n_components=5), PCA(n_components=8), 'passthrough'],\n",
    "    \n",
