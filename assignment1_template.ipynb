    "    'smote': ['passthrough', SMOTE(random_state=42)],\n",
    "    \n",
    "    # Random Forestin omat parametrit\n",
    "    'rf__n_estimators': [50, 100], \n",
    "    'rf__max_depth': [None, 10, 20] \n",
    "}\n",
    "\n",
    "# 3. Käytetään f1_macro -mittaria, jotta harvinaiset luokat huomioidaan paremmin\n",
    "grid_search_rf = GridSearchCV(rf_pipeline, param_grid, cv=3, scoring='f1_macro', n_jobs=-1)\n",
    "\n",
    "# Paras löydetty yhdistelmä: \n",
    "# {'pca': 'passthrough', 'rf__max_depth': 20, 'rf__n_estimators': 100, 'scaler': StandardScaler(), 'smote': SMOTE(random_state=42)}"
